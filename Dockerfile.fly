# Demo deploy image (Fly). Single stage: full source + node_modules so prisma
# generate/migrate/seed all work in-container without path surgery.
FROM node:20-alpine
WORKDIR /app
COPY package*.json ./
RUN npm ci --no-audit --no-fund
COPY . .
RUN npx prisma generate --schema src/prisma/schema.prisma && npx nx build api --skip-nx-cache
ENV PORT=8080
ENV HOST=0.0.0.0
CMD ["node", "dist/api/main.js"]
